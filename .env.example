# Copy to .env and adjust. All vars are prefixed LCCN_ (see predictor/config.py).

# --- Database ---
LCCN_MONGODB_URI=mongodb://localhost:27017
LCCN_DB_NAME=lccn_predictor

# --- LeetCode endpoints (rarely need changing) ---
LCCN_LEETCODE_BASE_US=https://leetcode.com
LCCN_LEETCODE_BASE_CN=https://leetcode.cn

# --- Crawler tuning ---
LCCN_RANKING_CONCURRENCY=8
LCCN_RATING_CONCURRENCY=8
# Users resolved per GraphQL request (aliased batch). ~40 is safe; this is the
# single biggest speed lever for full-contest predictions. Higher risks
# GraphQL query-complexity limits.
LCCN_RATING_BATCH_SIZE=40
LCCN_HTTP_RETRY=10
# Treat a cached user rating as fresh for this many hours (avoid refetching).
LCCN_RATING_CACHE_TTL_HOURS=12

# --- API ---
# In production set this to your website's exact origin, e.g. https://your-site.com
LCCN_CORS_ORIGINS=*
# Secret that gates crawl-triggering endpoints (admin predict, refresh) via the
# X-API-Key header. Leave empty only for local dev. Generate: openssl rand -hex 24
LCCN_API_KEY=
# When false (recommended for public deploys), /predict serves cached results
# only and never starts a live crawl. Set true for local/testing convenience.
LCCN_PUBLIC_CRAWL_ENABLED=true
# Per-IP rate limit for public reads (requests/minute). 0 disables.
LCCN_RATE_LIMIT_PER_MINUTE=120

# --- Scheduler ---
# Optional rating-cache warm-up (keeps cold-starts fast on always-on hosting).
LCCN_SCHEDULER_ENABLED=false
LCCN_SCHEDULER_INTERVAL_MINUTES=360
# Optional in-process auto-predict of the latest finished contest. Best for
# always-on/paid hosting. On free tiers that sleep, leave false and use the
# GitHub Actions cron (.github/workflows/predict-cron.yml) instead.
LCCN_AUTO_PREDICT_ENABLED=false
LCCN_AUTO_PREDICT_INTERVAL_MINUTES=30
